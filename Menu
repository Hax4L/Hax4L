local function saveSession(key)
    pcall(function()
        writefile(CONFIG.SAVE_FILE, HttpService:JSONEncode({
            key = key, hwid = HWID, time = os.time()
        }))
    end)
end

local function loadSession()
    local ok, raw = pcall(function() return readfile(CONFIG.SAVE_FILE) end)
    if not ok or not raw then return nil end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or not data then return nil end
    return data
end

local function clearSession()
    pcall(function() delfile(CONFIG.SAVE_FILE) end)
end

