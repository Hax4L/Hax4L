-- ════════════════════════════════════════
--  🔐 DJB2 HASH (giống JS)
-- ════════════════════════════════════════
local function djb2(str)
    local h = 5381
    for i = 1, #str do
        h = (h * 33 + string.byte(str, i)) % 4294967296
    end
    return math.floor(h)
end

-- ════════════════════════════════════════
--  🔑 KEY FUNCTIONS
-- ════════════════════════════════════════
local function generateKey()
    local ts = os.time()
    local tsHex = string.format("%08X", ts)

    -- Random 4 bytes
    local rndBytes = {}
    for i = 1, 4 do
        rndBytes[i] = string.format("%02X", math.random(0, 255))
    end
    local rndHex = table.concat(rndBytes)

    -- Checksum
    local chkHex = string.format("%08X", djb2(tsHex .. rndHex .. CONFIG.SECRET))

    return "HAX4L-" .. tsHex .. "-" .. rndHex .. "-" .. chkHex
end

local function verifyKey(key)
    if not key or key == "" then return false, "Không có key" end
    key = string.upper(key:gsub("%s+", ""))

    local parts = {}
    for part in key:gmatch("[^%-]+") do parts[#parts + 1] = part end

    if #parts ~= 4 or parts[1] ~= "HAX4L" then return false, "Sai định dạng" end
    if #parts[2] ~= 8 or #parts[3] ~= 8 or #parts[4] ~= 8 then return false, "Sai độ dài" end

    local expected = string.format("%08X", djb2(parts[2] .. parts[3] .. CONFIG.SECRET))
    if parts[4] ~= expected then return false, "Key giả mạo" end

    local ts = tonumber(parts[2], 16)
    if not ts then return false, "Timestamp lỗi" end

    local now = os.time()
    if now - ts > 86400 then return false, "Hết hạn" end
    if ts > now + 300 then return false, "Không hợp lệ" end

    local remain = 86400 - (now - ts)
    local rH = math.floor(remain / 3600)
    local rM = math.floor((remain % 3600) / 60)
    return true, string.format("Còn %dh %dm", rH, rM)
end

