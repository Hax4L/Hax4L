-- TỰ ĐỘNG ĐĂNG NHẬP NẾU KEY CÒN HẠN
if savedData and savedData.date == today and savedData.hwid == userHWID then
    local activatedTime = savedData.activatedTime
    local elapsed = os.time() - activatedTime
    local remaining = (24 * 3600) - elapsed
    
    if remaining > 0 then
        print("============================================")
        print("✅ TỰ ĐỘNG ĐĂNG NHẬP THÀNH CÔNG!")
        print("Key:", savedData.key)
        print("HWID:", userHWID)
        print("Thời gian còn:", math.floor(remaining/3600) .. "h " .. math.floor((remaining%3600)/60) .. "m")
        print("============================================")
        
        StarterGui:SetCore("SendNotification", {
