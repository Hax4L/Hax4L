        end
    end
end

local function loadSession()
    -- Backend 1: File (ưu tiên — tồn tại giữa các session)
    if CAN_SAVE_FILE then
        local ok, raw = pcall(function()
            if typeof(isfile) == "function" and not isfile(CONFIG.SAVE_FILE) then
                return nil
            end
            return readfile(CONFIG.SAVE_FILE)
        end)
        if ok and raw and raw ~= "" then
            local ok2, data = pcall(function()
                return HttpService:JSONDecode(raw)
            end)
            if ok2 and data and data.key and data.hwid then
                log("📂 Loaded from FILE — key: " .. string.sub(data.key, 1, 18) .. "...")
                return data
            end
        end
    end

    -- Backend 2: _G
    if _G.__HAX4L_SESSION and _G.__HAX4L_SESSION.key then
        log("📂 Loaded from _G")
        return _G.__HAX4L_SESSION
    end

    log("📂 No session found")
    return nil
end

local function clearSession()
    _G.__HAX4L_SESSION = nil
    if CAN_SAVE_FILE then
        pcall(function()
            if typeof(delfile) == "function" then
                delfile(CONFIG.SAVE_FILE)
            else
                writefile(CONFIG.SAVE_FILE, "")
            end
        end)
    end
    log("🗑️ Session cleared")
end

