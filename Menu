-- ═══ LẤY KEY ═══
GetBtn.MouseButton1Click:Connect(function()
    setStatus("⏳ Đang tạo key & link vượt...", C.yellow)
    GetBtn.Active = false
    TweenService:Create(GetBtn, TweenInfo.new(0.2), {
        BackgroundColor3 = Color3.fromRGB(55, 55, 65)
    }):Play()

    local key   = generateKey()
    local cbUrl = CONFIG.CALLBACK_URL .. "?key=" .. HttpService:UrlEncode(key)

    local apiUrl = "https://link4m.co/api-shorten/v2?api="
                 .. CONFIG.API_TOKEN
                 .. "&url=" .. HttpService:UrlEncode(cbUrl)

    local shortUrl = nil
    local ok, res = pcall(function() return game:HttpGet(apiUrl) end)
    if ok and res then
        local ok2, data = pcall(function() return HttpService:JSONDecode(res) end)
        if ok2 and data and data.status == "success" and data.shortenedUrl then
            shortUrl = data.shortenedUrl:gsub("\\/", "/")
        end
    end
    if not shortUrl then shortUrl = cbUrl end

    local copied = false
    pcall(function()
        if setclipboard then setclipboard(shortUrl); copied = true
        elseif toclipboard then toclipboard(shortUrl); copied = true end
    end)

    if copied then
        setStatus(
            "✅ Link đã copy vào clipboard!\n\n"
            .. "📋 Mở trình duyệt → Dán link (Ctrl+V)\n"
            .. "→ Vượt link → Nhận key → Quay lại dán key",
            C.cyan
        )
    else
        setStatus("🔗 Mở link này trong trình duyệt:\n\n" .. shortUrl, C.cyan)
    end

    GetBtn.Active = true
    TweenService:Create(GetBtn, TweenInfo.new(0.3), {BackgroundColor3 = C.accent}):Play()
end)

-- ═══ NHẬP KEY ═══
local function handleSubmit()
    local key = string.upper(KeyInp.Text:gsub("%s+", ""))

    if key == "" then
        setStatus("❌ Vui lòng nhập key!", C.red)
        shakeGUI()
        return
    end

    SubmitBtn.Active = false
    SubmitBtn.AutoButtonColor = false
    TweenService:Create(SubmitBtn, TweenInfo.new(0.2), {
        BackgroundColor3 = Color3.fromRGB(55, 55, 65)
    }):Play()

    setStatus("⏳ Đang kiểm tra key...", C.yellow)
    task.wait(0.8)

    local valid, msg = verifyKey(key)

    if valid then
        log("✅ Key hợp lệ: " .. msg)

        -- 💾 LƯU SESSION
        saveSession(key)

        setStatus(
            "✅ Key hợp lệ! " .. msg
            .. "\n🔒 Ghi nhớ thiết bị • Đang tải Hax4L..."
            .. "\n🔄 Lần sau tự động đăng nhập!",
            C.green
        )

        TweenService:Create(mStroke, TweenInfo.new(0.5), {
            Color = C.green, Transparency = 0
        }):Play()

        task.wait(2)

        closeGUI(function()
            loadMainScript()
        end)
    else
        log("❌ Key lỗi: " .. msg)
        setStatus("❌ " .. msg .. '\nBấm "Lấy Key" để nhận key mới.', C.red)
        shakeGUI()

        SubmitBtn.Active = true
        SubmitBtn.AutoButtonColor = true
        TweenService:Create(SubmitBtn, TweenInfo.new(0.3), {
            BackgroundColor3 = C.primaryD
        }):Play()
    end
end

SubmitBtn.MouseButton1Click:Connect(handleSubmit)

KeyInp.FocusLost:Connect(function(enter)
    if enter then
        task.wait(0.05)
        handleSubmit()
    end
end)

