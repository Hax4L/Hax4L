-- ════════════════════════════════════════
local function getHWID()
    local fns = {
        function() return gethwid() end,
        function() return getdeviceid() end,
        function() return getfingerprint() end,
        function() return game:GetService("RbxAnalyticsService"):GetClientId() end,
    }
    for _, fn in ipairs(fns) do
        local ok, r = pcall(fn)
        if ok and r and tostring(r) ~= "" then return tostring(r) end
    end
    return "UID_" .. tostring(player.UserId)
end

local HWID = getHWID()

