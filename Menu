            Text = "✅ Tự động đăng nhập!\nKey còn: " .. math.floor(remaining/3600) .. "h " .. math.floor((remaining%3600)/60) .. "m",
            Duration = 5
        })
        
        loadLeafHub(remaining, savedData.key)
        return
    else
        if delfile then delfile(SAVE_FILE) end
        StarterGui:SetCore("SendNotification", {
            Title = "HAX4L",
            Text = "⏰ Key đã hết hạn! Vui lòng lấy key mới",
            Duration = 5
        })
    end
end

