    setclipboard(shortLink)
    
    if request then pcall(function() request({Url=shortLink,Method="GET"}) end) end
    if syn and syn.request then pcall(function() syn.request({Url=shortLink,Method="GET"}) end) end
    
    StarterGui:SetCore("SendNotification", {
        Title = "HAX4L",
        Text = "Web đã mở! Vượt link → Copy key",
