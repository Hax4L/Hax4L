--  🔗 LẤY KEY (Tạo Key → Link4m → Clipboard)
-- ════════════════════════════════════════
GetBtn.MouseButton1Click:Connect(function()
    setStatus("⏳ Đang tạo key & link vượt...", C.yellow)

    GetBtn.Active = false
    TweenService:Create(GetBtn, TweenInfo.new(0.2), {
        BackgroundColor3 = Color3.fromRGB(55, 55, 65)
    }):Play()

    -- 1. Generate unique key
    local key = generateKey()

    -- 2. Build callback URL
    local cbUrl = CONFIG.CALLBACK_URL .. "?key=" .. HttpService:UrlEncode(key)

    -- 3. Shorten via Link4m
    local apiUrl = "https://link4m.co/api-shorten/v2?api="
                 .. CONFIG.API_TOKEN
                 .. "&url=" .. HttpService:UrlEncode(cbUrl)

    local shortUrl = nil

    local ok, res = pcall(function()
        return game:HttpGet(apiUrl)
    end)

    if ok and res then
        local ok2, data = pcall(function()
            return HttpService:JSONDecode(res)
        end)
        if ok2 and data and data.status == "success" and data.shortenedUrl then
            shortUrl = data.shortenedUrl:gsub("\\/", "/")
        end
    end

    -- Fallback if API fails
    if not shortUrl then
        shortUrl = cbUrl
    end

    -- 4. Copy to clipboard
    local copied = false
    pcall(function()
        if setclipboard then setclipboard(shortUrl); copied = true
        elseif toclipboard then toclipboard(shortUrl); copied = true end
    end)

    if copied then
        setStatus(
            "✅ Link đã copy vào clipboard!\n\n"
            .. "📋 Mở trình duyệt → Dán link (Ctrl+V)\n"
            .. "→ Vượt link → Nhận key → Quay lại dán key",
            Color3.fromRGB(34, 211, 238)
        )
    else
        setStatus(
            "🔗 Mở link này trong trình duyệt:\n\n"
            .. shortUrl,
            Color3.fromRGB(34, 211, 238)
        )
    end

    -- Re-enable
    GetBtn.Active = true
    TweenService:Create(GetBtn, TweenInfo.new(0.3), {BackgroundColor3 = C.accent}):Play()
end)

