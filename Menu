-- ============================================
-- LẤY HWID CỦA MÁY (FIX CHO MỌI EXECUTOR)
-- ============================================
local function getHWID()
    local hwid = nil
    
    -- Phương án 1: gethwid() - Synapse X, Script-Ware, Krnl
    if gethwid then
        hwid = gethwid()
    end
    
    -- Phương án 2: RbxAnalyticsService (Delta, Solara, Fluxus)
    if not hwid or hwid == "" then
        local success, result = pcall(function()
            return game:GetService("RbxAnalyticsService"):GetClientId()
        end)
        if success and result then
            hwid = result
        end
    end
    
    -- Phương án 3: Tạo HWID từ fingerprint (Arceus X, Hydrogen, mobile executors)
    if not hwid or hwid == "" then
        local fingerprint = {
            UserId = Players.LocalPlayer.UserId,
            AccountAge = Players.LocalPlayer.AccountAge,
            Name = Players.LocalPlayer.Name,
            DisplayName = Players.LocalPlayer.DisplayName,
            Locale = Players.LocalPlayer.LocaleId,
            OsPlatform = (game:GetService("UserInputService"):GetPlatform() or Enum.Platform.None).Name,
            TimeZone = os.date("%z")
        }
        
        local fingerprintStr = HttpService:JSONEncode(fingerprint)
        local hash = 0
        for i = 1, #fingerprintStr do
            hash = ((hash * 31) + string.byte(fingerprintStr, i)) % 2147483647
        end
        hwid = string.format("HWID-%X", hash)
    end
    
    -- Fallback cuối cùng (nếu tất cả fail)
    if not hwid or hwid == "" then
        hwid = "HWID-" .. Players.LocalPlayer.UserId .. "-" .. tostring(os.time())
    end
    
    return tostring(hwid)
end

-- ============================================
-- TẠO KEY DỰA TRÊN HWID + NGÀY (GIỐNG WEB)
-- ============================================
local function generateKeyFromHWID(hwid)
    local today = os.date("%Y-%m-%d")
    local combined = tostring(hwid) .. today
    
    local hash = 0
    for i = 1, #combined do
        hash = ((hash * 32) - hash) + string.byte(combined, i)
        hash = hash % 2147483647
    end
    
    local chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"
    local key = "HAX4L-"
    for i = 1, 12 do
        if i > 1 and (i-1) % 4 == 0 then key = key .. "-" end
        local index = (math.abs(hash + i * 13) % #chars) + 1
        key = key .. string.sub(chars, index, index)
    end
    
    return key
end

