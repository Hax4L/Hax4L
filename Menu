-- LẤY HWID
local function getHWID()
    local hwid = nil
    if gethwid then hwid = gethwid() end
    if not hwid or hwid == "" then
        pcall(function() hwid = game:GetService("RbxAnalyticsService"):GetClientId() end)
    end
    if not hwid or hwid == "" then
        hwid = "HWID-" .. Players.LocalPlayer.UserId
    end
    return tostring(hwid)
end

-- LOAD DATABASE KEY
local keyDatabase = {}
local function loadKeyDatabase()
    if isfile and readfile and isfile("HAX4L_KeyDB.json") then
        pcall(function()
            keyDatabase = HttpService:JSONDecode(readfile("HAX4L_KeyDB.json"))
        end)
    end
end

local function saveKeyDatabase()
    if writefile then
        writefile("HAX4L_KeyDB.json", HttpService:JSONEncode(keyDatabase))
    end
end

loadKeyDatabase()

-- KIỂM TRA KEY ĐÃ LƯU
local SAVE_FILE = "HAX4L_KeyData.json"
local savedData = nil

if isfile and readfile and isfile(SAVE_FILE) then
    pcall(function()
        savedData = HttpService:JSONDecode(readfile(SAVE_FILE))
    end)
end

local userHWID = getHWID()
local today = os.date("%Y-%m-%d")

-- ============================================
-- TỰ ĐỘNG ĐĂNG NHẬP (KHÔNG CẦN NHẬP KEY LẠI)
-- ============================================
if savedData and savedData.hwid == userHWID then
    -- Kiểm tra ngày
    if savedData.date == today then
        -- Key còn hạn trong ngày
        local activatedTime = savedData.activatedTime
        local elapsed = os.time() - activatedTime
        local remaining = (24 * 3600) - elapsed
        
        if remaining > 0 then
            -- ✅ TỰ ĐỘNG ĐĂNG NHẬP THÀNH CÔNG
            print("╔════════════════════════════════════════╗")
            print("║  ✅ TỰ ĐỘNG ĐĂNG NHẬP THÀNH CÔNG!      ║")
            print("╠════════════════════════════════════════╣")
            print("║  Key:", savedData.key)
            print("║  HWID:", userHWID)
            print("║  Thời gian còn:", math.floor(remaining/3600) .. "h " .. math.floor((remaining%3600)/60) .. "m")
            print("╚════════════════════════════════════════╝")
            
            StarterGui:SetCore("SendNotification", {
                Title = "HAX4L × LEAF HUB",
                Text = "✅ Tự động đăng nhập thành công!\nKey còn: " .. math.floor(remaining/3600) .. "h " .. math.floor((remaining%3600)/60) .. "m",
                Duration = 6,
                Icon = LOGO_IMAGE_ID
            })
            
            loadLeafHub(remaining, savedData.key)
            return
        else
            -- Key hết hạn (quá 24h)
            print("⏰ Key đã hết hạn (quá 24h)! Cần nhập key mới")
            if delfile then delfile(SAVE_FILE) end
            
            StarterGui:SetCore("SendNotification", {
                Title = "HAX4L",
                Text = "⏰ Key đã hết hạn (24h)!\nVui lòng lấy key mới",
                Duration = 6
            })
        end
    else
        -- Ngày khác → Key hết hạn
        print("⏰ Key đã hết hạn (ngày mới)! Cần nhập key mới")
        if delfile then delfile(SAVE_FILE) end
        
        StarterGui:SetCore("SendNotification", {
            Title = "HAX4L",
            Text = "⏰ Ngày mới! Vui lòng lấy key mới",
            Duration = 6
        })
    end
end

