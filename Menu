        return HttpService:JSONDecode(readfile(SAVE_FILE))
    end)
    if success then savedData = data end
end

local userHWID = getHWID()
local CORRECT_KEY = generateKeyFromHWID(userHWID)
local today = os.date("%Y-%m-%d")

print("============================================")
print("DEBUG INFO:")
print("HWID:", userHWID)
print("Key:", CORRECT_KEY)
print("Date:", today)
print("============================================")

-- Kiểm tra key đã lưu
if savedData and savedData.key == CORRECT_KEY and savedData.hwid == userHWID and savedData.date == today then
    local activatedTime = savedData.activatedTime
    local elapsed = os.time() - activatedTime
    local remaining = (24 * 3600) - elapsed
    
    if remaining > 0 then
        print("✅ Key hợp lệ! Thời gian còn: " .. math.floor(remaining/3600) .. " giờ " .. math.floor((remaining%3600)/60) .. " phút")
        loadLeafHub(remaining)
        return
    else
        print("⏰ Key đã hết hạn! Vui lòng lấy key mới")
        if delfile then delfile(SAVE_FILE) end
    end
end

