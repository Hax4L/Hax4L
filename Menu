-- LẤY HWID
local function getHWID()
    local hwid = nil
    if gethwid then hwid = gethwid() end
    if not hwid or hwid == "" then
        pcall(function() hwid = game:GetService("RbxAnalyticsService"):GetClientId() end)
    end
    if not hwid or hwid == "" then
        hwid = "HWID-" .. Players.LocalPlayer.UserId
    end
    return tostring(hwid)
end

-- KIỂM TRA KEY
local SAVE_FILE = "HAX4L_KeyData.json"
local savedData = nil

if isfile and readfile and isfile(SAVE_FILE) then
    pcall(function()
        savedData = HttpService:JSONDecode(readfile(SAVE_FILE))
    end)
end

local userHWID = getHWID()
local today = os.date("%Y-%m-%d")

if savedData and savedData.date == today then
    local activatedTime = savedData.activatedTime
    local elapsed = os.time() - activatedTime
    local remaining = (24 * 3600) - elapsed
    
    if remaining > 0 then
        print("✅ Key còn hạn: " .. math.floor(remaining/3600) .. "h")
        loadLeafHub(remaining)
        return
    else
        if delfile then delfile(SAVE_FILE) end
    end
end

