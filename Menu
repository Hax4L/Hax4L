    })
    
    StatusLabel.Text = "Lấy key xong → Dán vào đây"
    StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
end)

-- SUBMIT KEY
SubmitBtn.MouseButton1Click:Connect(function()
    local inputKey = KeyBox.Text:upper():gsub("%s+", "")
    
    -- Kiểm tra format
    if not inputKey:match("^HAX4L%-%w%w%w%w%-%w%w%w%w%-%w%w%w%w$") then
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        SubmitBtn.Text = "❌ SAI FORMAT!"
        StatusLabel.Text = "Key phải: HAX4L-XXXX-XXXX-XXXX"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        wait(2)
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 50)
        SubmitBtn.Text = "✓ XÁC NHẬN"
        return
    end
    
    -- Kiểm tra key đã được dùng chưa
    if keyDatabase[inputKey] then
        local lockedHWID = keyDatabase[inputKey]
        if lockedHWID ~= userHWID then
            -- Key đã lock vào máy khác
            SubmitBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            SubmitBtn.Text = "❌ KEY ĐÃ DÙNG!"
            StatusLabel.Text = "Key đã được dùng trên máy khác!"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            
            StarterGui:SetCore("SendNotification", {
                Title = "HAX4L",
                Text = "❌ Key này đã được dùng trên máy khác!\nVui lòng lấy key mới",
                Duration = 8
            })
            
            wait(3)
            SubmitBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 50)
            SubmitBtn.Text = "✓ XÁC NHẬN"
            return
        end
    else
        -- Key mới → Lock vào máy này
        keyDatabase[inputKey] = userHWID
        saveKeyDatabase()
        print("🔒 Đã lock key vào máy này:", inputKey)
    end
    
    SubmitBtn.Text = "⏳ ĐANG LƯU..."
    StatusLabel.Text = "Đang lưu key vĩnh viễn..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
    
    -- ============================================
    -- LƯU KEY VĨNH VIỄN (Không cần nhập lại)
    -- ============================================
    local keyData = {
        key = inputKey,
        hwid = userHWID,
        date = today,
        activatedTime = os.time()
    }
    
    if writefile then
        writefile(SAVE_FILE, HttpService:JSONEncode(keyData))
        print("💾 Đã lưu key vĩnh viễn:", inputKey)
    end
    
    SubmitBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    SubmitBtn.Text = "✅ ĐÃ LƯU!"
    StatusLabel.Text = "Key đã được lưu! Lần sau tự động đăng nhập"
    StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    
    StarterGui:SetCore("SendNotification", {
        Title = "HAX4L",
        Text = "✅ Key đã lưu thành công!\nLần sau không cần nhập lại",
        Duration = 6
    })
    
    wait(1.5)
    ScreenGui:Destroy()
    loadLeafHub(24 * 3600, inputKey)
end)

-- ============================================
-- LOAD LEAF HUB + TIMER
-- ============================================
function loadLeafHub(remainingSeconds, keyUsed)
    print("╔════════════════════════════════════════╗")
    print("║       HAX4L × LEAF HUB LOADED          ║")
    print("╠════════════════════════════════════════╣")
    print("║  Key:", keyUsed)
    print("║  HWID:", userHWID)
    print("║  Thời gian:", math.floor(remainingSeconds/3600) .. "h")
    print("║  Lưu: Vĩnh viễn (tự động đăng nhập)   ║")
    print("╚════════════════════════════════════════╝")
    
    -- Timer nhỏ gọn
    local TimeGui = Instance.new("ScreenGui")
    local TimeButton = Instance.new("TextButton")
    local TimeCorner = Instance.new("UICorner")
    
    TimeGui.Name = "HAX4L_Timer"
    TimeGui.Parent = game.CoreGui
    TimeGui.ResetOnSpawn = false
    
    TimeButton.Parent = TimeGui
    TimeButton.BackgroundColor3 = Color3.fromRGB(0, 20, 0)
    TimeButton.BackgroundTransparency = 0.3
    TimeButton.BorderSizePixel = 0
    TimeButton.Position = UDim2.new(1, -90, 0, 10)
    TimeButton.Size = UDim2.new(0, 80, 0, 30)
    TimeButton.Font = Enum.Font.GothamBold
    TimeButton.TextColor3 = Color3.fromRGB(0, 255, 65)
    TimeButton.TextSize = 11
    TimeButton.AutoButtonColor = false
    TimeCorner.CornerRadius = UDim.new(0, 8)
    TimeCorner.Parent = TimeButton
    
    -- Hover
    TimeButton.MouseEnter:Connect(function()
        TweenService:Create(TimeButton, TweenInfo.new(0.2), {
            BackgroundTransparency = 0.1, 
            Size = UDim2.new(0, 120, 0, 40)
        }):Play()
    end)
    
    TimeButton.MouseLeave:Connect(function()
        TweenService:Create(TimeButton, TweenInfo.new(0.2), {
            BackgroundTransparency = 0.3, 
            Size = UDim2.new(0, 80, 0, 30)
        }):Play()
    end)
    
    local startTime = os.time()
    spawn(function()
        while true do
            local remaining = remainingSeconds - (os.time() - startTime)
            
            if remaining <= 0 then
                TimeButton.Text = "⏰ HẾT HẠN"
                TimeButton.TextColor3 = Color3.fromRGB(255, 50, 50)
                wait(5)
                
                -- Xóa key đã hết hạn
                if delfile and isfile(SAVE_FILE) then 
                    delfile(SAVE_FILE)
                    print("🗑️ Đã xóa key hết hạn")
                end
                
                StarterGui:SetCore("SendNotification", {
                    Title = "HAX4L",
                    Text = "⏰ Key đã hết hạn (24h)!\nVui lòng lấy key mới",
                    Duration = 10
                })
                
                wait(2)
                game.Players.LocalPlayer:Kick("Key đã hết hạn (24h)!\nVui lòng lấy key mới tại:\n" .. KEY_WEBSITE)
                return
            end
            
            local h = math.floor(remaining/3600)
            local m = math.floor((remaining%3600)/60)
            TimeButton.Text = string.format("⏰ %02d:%02d", h, m)
            
            -- Đổi màu khi sắp hết
            if remaining <= 3600 then
                TimeButton.TextColor3 = Color3.fromRGB(255, 150, 0)
            elseif remaining <= 600 then
                TimeButton.TextColor3 = Color3.fromRGB(255, 50, 50)
            end
            
            wait(60)
        end
    end)
    
    -- Load Leaf Hub
    local success, err = pcall(function()
        loadstring(game:HttpGet(LEAF_HUB_URL))()
    end)
    
    if success then
        StarterGui:SetCore("SendNotification", {
            Title = "HAX4L × LEAF HUB",
            Text = "✅ Loaded thành công!\nKey còn: " .. math.floor(remainingSeconds/3600) .. "h",
            Duration = 5,
            Icon = LOGO_IMAGE_ID
        })
    else
        warn("❌ Lỗi load Leaf Hub:", err)
        StarterGui:SetCore("SendNotification", {
            Title = "HAX4L",
            Text = "❌ Lỗi load Leaf Hub!\nVui lòng thử lại",
            Duration = 5
        })
    end
end
