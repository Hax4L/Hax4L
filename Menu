-- ============================================
-- LOAD LEAF HUB + HIỆN THỜI GIAN
-- ============================================
function loadLeafHub(remainingSeconds)
    print("============================================")
    print("       HAX4L × LEAF HUB")
    print("============================================")
    
    local TimeGui = Instance.new("ScreenGui")
    local TimeFrame = Instance.new("Frame")
    local UICorner = Instance.new("UICorner")
    local TimeLabel = Instance.new("TextLabel")
    local UIGradient = Instance.new("UIGradient")
    
    TimeGui.Name = "HAX4L_Timer"
    TimeGui.Parent = game.CoreGui
    TimeGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    TimeGui.ResetOnSpawn = false
    
    TimeFrame.Parent = TimeGui
    TimeFrame.BackgroundColor3 = Color3.fromRGB(0, 20, 0)
    TimeFrame.BackgroundTransparency = 0.2
    TimeFrame.BorderSizePixel = 3
    TimeFrame.BorderColor3 = Color3.fromRGB(0, 255, 65)
    TimeFrame.Position = UDim2.new(0, 10, 0, 10)
    TimeFrame.Size = UDim2.new(0, 280, 0, 70)
    
    UICorner.CornerRadius = UDim.new(0, 12)
    UICorner.Parent = TimeFrame
    
    UIGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 40, 0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 15, 0))
    }
    UIGradient.Rotation = 90
    UIGradient.Parent = TimeFrame
    
    TimeLabel.Parent = TimeFrame
    TimeLabel.BackgroundTransparency = 1
    TimeLabel.Size = UDim2.new(1, 0, 1, 0)
    TimeLabel.Font = Enum.Font.GothamBold
    TimeLabel.TextColor3 = Color3.fromRGB(0, 255, 65)
    TimeLabel.TextSize = 16
    TimeLabel.TextStrokeTransparency = 0.3
    TimeLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    local startTime = os.time()
    local function updateTimer()
        local elapsed = os.time() - startTime
        local remaining = remainingSeconds - elapsed
        
        if remaining <= 0 then
            TimeLabel.Text = "⏰ KEY HẾT HẠN!"
            TimeLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            TimeFrame.BorderColor3 = Color3.fromRGB(255, 50, 50)
            wait(5)
            TimeGui:Destroy()
            if delfile and isfile(SAVE_FILE) then delfile(SAVE_FILE) end
            game.Players.LocalPlayer:Kick("Key đã hết hạn!\n" .. KEY_WEBSITE)
            return
        end
        
        local hours = math.floor(remaining / 3600)
        local minutes = math.floor((remaining % 3600) / 60)
        local seconds = remaining % 60
        
        if remaining <= 3600 then
            TimeLabel.TextColor3 = Color3.fromRGB(255, 150, 0)
            TimeFrame.BorderColor3 = Color3.fromRGB(255, 150, 0)
        elseif remaining <= 600 then
            TimeLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            TimeFrame.BorderColor3 = Color3.fromRGB(255, 50, 50)
        end
        
        TimeLabel.Text = string.format("⏰ HAX4L × LEAF HUB\n⏳ Còn: %02d:%02d:%02d", hours, minutes, seconds)
    end
    
    spawn(function()
        while true do
            updateTimer()
            wait(1)
        end
    end)
    
    StarterGui:SetCore("SendNotification", {
        Title = "HAX4L × LEAF HUB",
        Text = "Đang load Leaf Hub...",
        Duration = 5
    })
    
    local success, result = pcall(function()
        return loadstring(game:HttpGet(LEAF_HUB_URL))()
    end)
    
    if success then
        print("✅ Leaf Hub loaded!")
        StarterGui:SetCore("SendNotification", {
            Title = "HAX4L × LEAF HUB",
            Text = "✅ Leaf Hub đã load thành công!",
            Duration = 5
        })
    else
        warn("❌ Lỗi:", result)
        StarterGui:SetCore("SendNotification", {
            Title = "HAX4L × LEAF HUB",
            Text = "❌ Lỗi load! Thử lại",
            Duration = 10
        })
    end
end
